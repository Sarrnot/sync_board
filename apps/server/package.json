{
    "name": "server",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "lint:file": "eslint",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@ts-rest/core": "3.53.0-rc.1",
        "@ts-rest/express": "3.53.0-rc.1",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "postgres": "^3.4.9",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.5.3",
        "@sync_board/eslint-config": "workspace:*",
        "@types/express": "^5.0.6",
        "@types/node": "^24.12.2",
        "@types/supertest": "^7.2.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.4.1",
        "globals": "^17.6.0",
        "supertest": "^7.2.2",
        "tsx": "^4.22.4",
        "typescript": "~6.0.3",
        "vitest": "^4.1.8"
    }
}
