{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",

        /* Language & modules — target the Node 24 runtime */
        "target": "es2024",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": ["node"],

        /* Emit */
        "outDir": "./dist",
        "rootDir": "./src",
        "sourceMap": true
    },
    "include": ["src"]
}
