{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        /* Language & modules — target the Node 24 runtime */
        "target": "es2024",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": ["node"],

        /* Type-check only; emit is configured in tsconfig.build.json */
        "noEmit": true
    },
    "exclude": ["node_modules", "dist"]
}
